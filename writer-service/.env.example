# writer-service
WRITER_SERVICE_PORT=8787
WRITER_SERVICE_TOKEN=change_me_to_a_random_secret_at_least_32_chars
WRITER_SERVICE_MAX_BODY=2mb
WRITER_SERVICE_MAX_CONCURRENT=2
WRITER_SERVICE_TEMP_DIR=/tmp
WRITER_SERVICE_PROMPTS_DIR=../prompts

# Claude Code CLI
CLAUDE_CODE_COMMAND=claude
CLAUDE_CODE_MAX_TURNS=3
CLAUDE_CODE_TIMEOUT_MS=600000

# API keys (passed through to Claude Code via environment)
ANTHROPIC_API_KEY=change_me
