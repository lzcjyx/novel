# ============================================================================
# AI Novel Factory — Environment Variables
# 复制为 .env 并填入真实值 / Copy to .env with real values
# ============================================================================

# --- Database (Docker 自动创建，无需手动建库) ---
# 在下面设一个密码即可，Docker Compose 会创建数据库、用户、表
# Just set a password — Docker creates database, user, tables automatically
DB_PASSWORD=novel123
NEON_DATABASE_URL_POOLED=postgresql://novel:${DB_PASSWORD:-novel123}@localhost:5432/novel_factory?sslmode=disable
NEON_DATABASE_URL_DIRECT=postgresql://novel:${DB_PASSWORD:-novel123}@localhost:5432/novel_factory?sslmode=disable
EMBEDDING_DIMENSION=1536

# --- Writer Service (REQUIRED) ---
WRITER_SERVICE_TOKEN=CHANGE_ME_TO_RANDOM_64_HEX
WRITER_MODEL=claude-sonnet-4-6
WRITER_MAX_TOKENS=8192

# --- AI Provider (REQUIRED) — DeepSeek gives both Anthropic+OpenAI compat ---
ANTHROPIC_API_KEY=sk-CHANGE_ME
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_API_KEY=sk-CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME

# --- n8n API Key — get from n8n Settings > API Keys after first start ---
N8N_API_KEY=CHANGE_ME

# --- Scheduler (optional) ---
SCHEDULE_TIMEZONE=Asia/Shanghai
SCHEDULE_DAILY_HOUR=18
MIN_CHAPTER_PLANS=3
ORCHESTRATOR_PORT=3001

# --- Output directory (optional, default ./data/paper) ---
PAPER_DIR=./data/paper

# --- Quality (optional) ---
DEFAULT_QUALITY_THRESHOLD=85
MAX_REVISE_COUNT=2

# --- Blog (optional) ---
BLOG_PROVIDER=wordpress
WORDPRESS_BASE_URL=https://example.com
WORDPRESS_USERNAME=change_me
WORDPRESS_APP_PASSWORD=change_me
