        "jsCode": "const project = $('Load Active Project').first().json;\nconst chapter = $('Call Writer Service').first().json.data;\nconst finalScore = $('Collect All Reviews').first().json.final_score;\nconst blogPost = $('Save Blog Post Record').first().json;\nconst job = $('Build Writing Brief').first().json;\nreturn [{\n  json: {\n    message: `📖 **${project.name}**\\n` +\n      `Chapter ${$('Select Next Chapter Plan').first().json.sequence}: ${chapter.title}\\n` +\n      `Words: ${chapter.word_count} | Score: ${finalScore}\\n` +\n      `Status: ${job.auto_publish && finalScore >= job.quality_threshold ? 'Published' : 'Draft'}\\n` +\n      `URL: ${blogPost.url || 'N/A'}`,\n    subject: `[Novel Factory] ${project.name} Ch${$('Select Next Chapter Plan').first().json.sequence} — Score ${finalScore}`,\n    project_title: project.name,\n    chapter_title: chapter.title,\n    word_count: chapter.word_count,\n    score: finalScore,\n    url: blogPost.url || '',\n    needs_human_review: false\n  }\n}];"
