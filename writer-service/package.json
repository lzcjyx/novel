{
  "name": "novel-writer-service",
  "version": "1.0.0",
  "description": "HTTP service that wraps Claude Code CLI for n8n novel generation pipeline",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "health": "node -e \"require('http').get('http://localhost:8787/health',r=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>{console.log(d);process.exit(r.statusCode===200?0:1)})})\"",
    "ready": "node -e \"require('http').get('http://localhost:8787/ready',r=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>{console.log(d);process.exit(r.statusCode===200?0:1)})})\""
  },
  "dependencies": {
    "express": "^4.21.0",
    "dotenv": "^16.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
