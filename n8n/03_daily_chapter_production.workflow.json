    {
      "parameters": {
        "jsCode": "var pid = $(\"Load Active Project\").first().json.id;\nreturn [{ json: { project_id: pid, canon_loaded: true, characters: [], canon_rules: [], world_lore: [] } }];"
      },
      "id": "node-009",
      "name": "Load Structured Canon",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        780
      ]
    },
    {
      "parameters": {
        "jsCode": "const chapterPlan = $('Select Next Chapter Plan').first().json;\nconst project = $('Load Active Project').first().json;\nconst queryParts = [\n  chapterPlan.title || '',\n  (chapterPlan.plot_goals || []).join(' '),\n  (chapterPlan.characters_involved || []).join(' '),\n  (chapterPlan.locations_involved || []).join(' '),\n  project.genre.join(' '),\n  project.tone || ''\n].filter(Boolean);\nconst retrievalQuery = queryParts.join(' ');\nreturn [{\n  json: {\n    retrieval_query: retrievalQuery,\n    project_id: project.id,\n    chapter_plan: chapterPlan,\n    top_k: 12\n  }\n}];"
      },
      "id": "node-010",
      "name": "Build Retrieval Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        780
      ]
    },
    {
      "parameters": {
        "jsCode": "var items = $input.all();\nreturn items.map(function(item) { return { json: { query_embedding: new Array(1536).fill(0), context: item.json } }; });"
      },
      "id": "node-011",
      "name": "Embed Retrieval Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        780
      ]
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(function(item) { return { json: { vector_context: [], project_id: item.json.project_id } }; });"
      },
      "id": "node-012",
      "name": "Retrieve Vector Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2220,
        780
      ]
    },
    {
      "parameters": {
        "jsCode": "const project = $('Load Active Project').first().json;\nconst chapterPlan = $('Select Next Chapter Plan').first().json;\nconst projectConfig = $('Load Project Config').all();\nconst structuredCanon = $('Load Structured Canon').all();\nconst vectorContext = $('Retrieve Vector Context').all();\nconst job = $('Acquire Lock').first().json;\nlet styleGuide = {};\nlet hardRules = [];\nlet softRules = [];\nlet recentSummaries = [];\nlet systemSettings = {};\nfor (const item of projectConfig) {\n  const j = item.json;\n  if (Array.isArray(j)) {\n  }\n  if (j.narrative_perspective) styleGuide = j;\n  if (j.rule_type === 'hard') hardRules.push(j);\n  if (j.rule_type === 'soft') softRules.push(j);\n  if (j.summary && j.sequence) recentSummaries.push(j);\n  if (j.key && j.value) systemSettings[j.key] = j.value;\n}\nlet characters = [];\nlet characterStates = [];\nlet locations = [];\nlet plotThreads = [];\nlet foreshadowing = [];\nlet timelineEvents = [];\nfor (const item of structuredCanon) {\n  const j = item.json;\n  if (j.role) characters.push(j);\n  if (j.physical_state || j.emotional_state) characterStates.push(j);\n  if (j.location_type) locations.push(j);\n  if (j.thread_type) plotThreads.push(j);\n  if (j.clue_text) foreshadowing.push(j);\n  if (j.event_time_label) timelineEvents.push(j);\n}\nconst writingBrief = {\n  project: {\n    id: project.id,\n    title: project.name,\n    genre: project.genre,\n    tone: project.tone,\n    style_profile: project.style_profile\n  },\n  chapter_plan: {\n    id: chapterPlan.id,\n    sequence: chapterPlan.sequence,\n    title: chapterPlan.title,\n    plot_goals: chapterPlan.plot_goals || [],\n    summary: chapterPlan.summary || '',\n    arc_stage: chapterPlan.arc_stage || '',\n    major_events: chapterPlan.major_events || []\n  },\n  target_word_count: chapterPlan.target_word_count || project.daily_target_words || 3000,\n  recent_summaries: recentSummaries.reverse(),\n  active_characters: characters,\n  character_states: characterStates,\n  locations: locations,\n  plot_threads: plotThreads,\n  foreshadowing: foreshadowing,\n  timeline_events: timelineEvents,\n  canon_rules: { hard: hardRules, soft: softRules },\n  style_guide: styleGuide,\n  retrieved_context: vectorContext.map(v => ({\n    id: v.json.id,\n    source_type: v.json.source_type,\n    title: v.json.title,\n    content: v.json.content,\n    similarity: v.json.similarity\n  })),\n  hard_constraints: hardRules.map(r => r.rule_text),\n  quality_threshold: project.quality_threshold || 85,\n  max_revise_count: project.max_revise_count || 2,\n  auto_publish: project.auto_publish || false\n};\nreturn [{\n  json: {\n    job_id: job.id,\n    project_id: project.id,\n    chapter_plan_id: chapterPlan.id,\n    writing_brief: writingBrief,\n    auto_publish: project.auto_publish || false,\n    quality_threshold: project.quality_threshold || 85,\n    max_revise_count: project.max_revise_count || 2\n  }\n}];"
      },
